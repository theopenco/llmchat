# Marketing site environment — copy to apps/marketing/.env.
# NEXT_PUBLIC_* values are baked into the browser bundle, so put PUBLIC values
# only here — never a secret or private key.

# Dashboard origin that the marketing CTAs / header / footer link to.
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3001

# --- Analytics (PostHog) ---
# Project API key (phc_…). Public/write-only — safe to ship in the browser
# bundle. Analytics no-op when this is unset, so local dev can leave it blank.
NEXT_PUBLIC_POSTHOG_KEY=
# Ingest host (EU cloud). Defaults to EU in code; use https://us.i.posthog.com
# for a US-region PostHog project.
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# --- Analytics (Google Analytics 4) ---
# GA4 measurement id (G-…). Public — ships in the browser bundle. Loads only
# after analytics consent (and never in EU/UK before opt-in). No-ops when unset.
NEXT_PUBLIC_GA_ID=

# --- Google Search Console ---
# Site-ownership verification token GSC gives you for the "HTML tag" method
# (the content="…" value). Rendered as a <meta> tag; omitted when unset.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
