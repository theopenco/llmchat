// Local workerd boot (`pnpm exec wrangler dev`), and — because @meetploy/cli
// uses a committed wrangler config verbatim instead of generating one from
// ploy.yaml — the dev-time source of truth for bindings. Binding names here
// MUST match the ploy.yaml bindings.
// NO trailing commas: Ploy's CLI strips comments but parses strict JSON
// (prettier is kept away via .prettierignore).
// Before first local boot: pnpm exec wrangler d1 migrations apply SESSION_DB --local
{
	"name": "clanker-shopify",
	"main": "./workers/app.ts",
	"compatibility_date": "2025-10-08",
	"compatibility_flags": ["nodejs_compat"],
	"d1_databases": [
		{
			"binding": "SESSION_DB",
			"database_name": "shopify_sessions",
			"database_id": "local-spike",
			"migrations_dir": "migrations"
		}
	],
	"assets": {
		"directory": "./build/client"
	},
	"vars": {
		"SCOPES": ""
	}
}
