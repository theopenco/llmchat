# Local dev: `shopify app dev` injects the SHOPIFY_* vars itself — the only
# var you need locally is DATABASE_URL (the Shopify CLI and Prisma both load
# this file). Production (Docker) needs all of them set on the host.

# SQLite database. Relative paths resolve against prisma/ (dev uses
# prisma/dev.sqlite). In production point at the mounted volume, e.g.
# "file:/data/prod.sqlite".
DATABASE_URL="file:dev.sqlite"

# --- Production-only below (injected by `shopify app dev` locally) ---

# Client ID + secret from the app's config (Partner/Dev dashboard, or
# `shopify app env show`).
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""

# The app's public origin — must match application_url in shopify.app.toml.
SHOPIFY_APP_URL="https://shopify.clankersupport.com"

# Must mirror [access_scopes] in shopify.app.toml (deliberately empty).
SCOPES=""

# Clanker API origin used to validate project keys (defaults to
# https://api.clankersupport.com when unset — only set for self-hosted).
# CLANKER_API_ORIGIN=""

# PORT=3000
