.cache
build
node_modules
# Never bake secrets or local state into image layers: the Shopify CLI writes
# SHOPIFY_API_SECRET into .env (`shopify app env pull`), and dev.sqlite holds
# local session data.
.env
.env.*
!.env.example
.react-router
.shopify
prisma/*.sqlite
prisma/*.sqlite-journal
Dockerfile
.dockerignore
# The theme app extension ships via `shopify app deploy`, not this image.
extensions
# Tests never run in the image.
**/*.test.ts
**/*.test.tsx
vitest.config.ts
