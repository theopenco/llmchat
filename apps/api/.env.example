# LLMChat API environment — copy to apps/api/.env and fill in real values.
# `ploy dev` interpolates these into the env: block of apps/api/ploy.yaml ($VAR).
# Real secrets must NEVER be committed; only this placeholder template is tracked.

# --- Inference (LLMGateway) ---
# LLMChat-owned LLMGateway API key. Server-side only — never expose to the browser.
LLMGATEWAY_API_KEY=
# LLMGateway base URL (OpenAI-compatible /v1).
LLMGATEWAY_BASE_URL=https://api.llmgateway.io/v1

# --- Auth (Better Auth) ---
# Session-signing secret, 32+ random chars. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public base URL where the API (and Better Auth) is served.
BETTER_AUTH_URL=http://localhost:8787

# --- Dashboard ---
# Origin allowed to call the authenticated /api/* routes (CORS + CSRF trust).
DASHBOARD_URL=http://localhost:3001

# --- Public widget CORS ---
# Public embed origins; "*" allows any customer site. Set as a literal in
# ploy.yaml (public config, not a secret) — listed here for reference.
WIDGET_ALLOWED_ORIGINS=*

# --- Email (Resend) ---
# Resend API key for outbound + escalation email.
RESEND_API_KEY=
# Verified from-address for outbound email.
RESEND_FROM_EMAIL=onboarding@resend.dev
# Domain for inbound reply addresses (reply+<local>@<domain>).
INBOUND_EMAIL_DOMAIN=example.com

# --- Billing (Stripe) — not active yet; billing is a 501 stub ---
# Stripe secret key (future).
STRIPE_SECRET_KEY=
# Stripe webhook signing secret (future).
STRIPE_WEBHOOK_SECRET=
