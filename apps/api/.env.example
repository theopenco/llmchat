# LLMChat API environment — copy to apps/api/.env and fill in real values.
# `ploy dev` interpolates these into the env: block of apps/api/ploy.yaml ($VAR).
# Real secrets must NEVER be committed; only this placeholder template is tracked.

# --- Inference (LLMGateway) ---
# LLMChat-owned LLMGateway API key. Server-side only — never expose to the browser.
LLMGATEWAY_API_KEY=
# LLMGateway base URL (OpenAI-compatible /v1).
LLMGATEWAY_BASE_URL=https://api.llmgateway.io/v1

# --- Auth (Better Auth) ---
# Session-signing secret, 32+ random chars. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public base URL where the API (and Better Auth) is served.
BETTER_AUTH_URL=http://localhost:8787

# --- Social sign-in (Better Auth, optional) ---
# Leave blank until the OAuth apps exist: each provider's "Continue with …"
# button stays disabled ("Soon") and /api/oauth-providers reports it off, so the
# app works fine without these. Set BOTH id+secret for a provider to enable it.
#
# Register these callback URLs when creating the apps (path is fixed by Better
# Auth: <BETTER_AUTH_URL>/api/auth/callback/<provider>):
#   Google Cloud Console → Credentials → OAuth client → Authorized redirect URIs:
#     http://localhost:8787/api/auth/callback/google   (local)
#     https://<api-domain>/api/auth/callback/google     (prod = BETTER_AUTH_URL)
#   GitHub → Developer settings → OAuth Apps → Authorization callback URL
#   (one URL per app, so register a separate dev app for localhost):
#     http://localhost:8787/api/auth/callback/github   (local)
#     https://<api-domain>/api/auth/callback/github     (prod)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Dashboard ---
# Origin allowed to call the authenticated /api/* routes (CORS + CSRF trust).
DASHBOARD_URL=http://localhost:3001

# --- Admin dashboard ---
# Origin of the internal admin console (apps/admin). Allowed to call /admin/* +
# /api/auth/* (CORS + Better Auth trust). Optional — defaults to
# http://localhost:3004 in dev. Prod: https://admin.clankersupport.com
ADMIN_URL=http://localhost:3004

# --- Email (Resend) ---
# Resend API key for outbound + escalation email.
RESEND_API_KEY=
# Verified from-address for outbound email.
RESEND_FROM_EMAIL=onboarding@resend.dev
# Domain for inbound reply addresses (reply+<local>@<domain>).
INBOUND_EMAIL_DOMAIN=example.com
# Resend inbound webhook signing secret (whsec_...). REQUIRED to accept inbound
# replies: the webhook verifies this Svix signature and rejects anything else.
# Unset ⇒ all inbound-email webhooks are rejected (fail-closed).
RESEND_INBOUND_WEBHOOK_SECRET=
# The request header Ploy's edge sets with the real client IP, used for ALL
# IP-scoped rate limiting (widget + Better Auth). Defaults to x-real-ip — what
# Ploy forwards for the api worker — so leaving this EMPTY is correct for our
# infra out-of-the-box (the default no longer depends on this var being set, which
# previously collapsed every visitor into one "unknown" bucket when unset). Only
# override for a different host (e.g. Cloudflare's cf-connecting-ip). We never
# trust x-forwarded-for (client-spoofable).
TRUSTED_CLIENT_IP_HEADER=

# --- Billing (Stripe) ---
# Secret API key (sk_live_… / sk_test_…). SERVER-SIDE ONLY — never commit, never
# expose to the browser, never NEXT_PUBLIC_*.
STRIPE_SECRET_KEY=
# Webhook signing secret (whsec_…) for /billing/webhook. From the Stripe
# dashboard webhook endpoint, or `stripe listen` for local testing. Secret.
STRIPE_WEBHOOK_SECRET=
# Recurring base Price id (price_…) for each paid tier. Public (safe to share),
# kept in env so it differs per environment/account. The collaborator creates
# these in Stripe; leave blank locally — billing endpoints return
# `billing_not_configured` until set, and local dev seeds a paid workspace.
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_SCALE=
# Annual base Price ids (price_…) — one per tier, billed yearly at 10× the
# monthly price (two months free). Selected when a workspace checks out on the
# yearly cadence. Leave blank to offer monthly only; annual checkout returns
# `billing_not_configured` until set.
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_GROWTH_ANNUAL=
STRIPE_PRICE_SCALE_ANNUAL=
# Metered OVERAGE Price ids (price_…) for the tiers that allow overage. Each is
# a metered/usage price whose tiering makes the first N units (the included
# monthly quota) free and bills per response beyond it. Starter has none — it
# hard-stops at its cap.
STRIPE_PRICE_GROWTH_OVERAGE=
STRIPE_PRICE_SCALE_OVERAGE=
# Stripe Billing Meter event name responses are reported under. Must match the
# meter the metered prices above are attached to. Defaults to `clanker_response`
# when unset.
STRIPE_METER_EVENT=

# --- Analytics (PostHog) ---
# Project API key (phc_…) used for server-side widget/conversation events.
# Same key as the browser apps' NEXT_PUBLIC_POSTHOG_KEY. Capture no-ops when
# unset, so local dev can leave it blank.
POSTHOG_API_KEY=
# Ingest host (EU cloud). Defaults to EU in code; use https://us.i.posthog.com
# for a US-region PostHog project.
POSTHOG_HOST=https://eu.i.posthog.com
# --- Notifications (Discord, optional) ---
# Discord incoming-webhook URL for operator pings: new signups, new subscribers,
# subscription cancellations. All notifications no-op when unset — local dev and
# self-hosters need zero Discord setup. Webhook URLs are SECRETS (anyone holding
# one can post to the channel) — never commit them.
DISCORD_NOTIFICATION_URL=
# Discord webhook for the weekly/monthly traffic report (separate channel).
DISCORD_TRAFFIC_NOTIFICATION_URL=

# --- Traffic report (PostHog query, optional) ---
# A Ploy cron (see ploy.yaml) posts a weekly (Mon 08:00 UTC) and monthly (1st
# 08:30 UTC) traffic digest to DISCORD_TRAFFIC_NOTIFICATION_URL by querying
# PostHog's HogQL API. Requires a PostHog *personal* API key with read scope
# (phx_… — distinct from the phc_ ingestion key above; create it under
# posthog.com → Settings → Personal API keys) plus the NUMERIC project id of
# the clankersupport PostHog project (visible in its URL). The report skips
# with a log line while any of these is unset.
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=
# PostHog APP host for the query API (NOT the eu.i ingest host). The
# clankersupport project lives on EU cloud; this default is baked into the code
# so the var can stay unset.
POSTHOG_QUERY_HOST=https://eu.posthog.com

# Internal/founder accounts that get full product access without paying (paywall
# + quota + metering bypassed). Comma-separated emails; matched server-side
# against the WORKSPACE OWNER's email (never client input). Leave blank in prod
# unless you mean it. Example: founder@yourco.com,ops@yourco.com
INTERNAL_ACCOUNT_EMAILS=

# Platform admins — comma-separated emails granted access to the internal admin
# dashboard (signups / revenue / subscriptions across all workspaces). Matched
# server-side against the SESSION user's email, and ONLY for a VERIFIED email, so
# an unverified self-registration can never self-elevate. This is the bootstrap
# path (a listed operator is an admin without a manual DB write); in-DB admins
# (user.role = 'admin') also work. Leave BLANK in prod unless you mean it — each
# listed address is a live admin grant. Local dev needs nothing here: the dev
# seed's admin@example.com is seeded with role='admin' (and pre-verified).
ADMIN_EMAILS=
