{
	"name": "llmchat",
	"private": true,
	"license": "SEE LICENSE IN LICENSE",
	"scripts": {
		"build": "turbo run build",
		"clean": "find . -path \"./node_modules\" -prune -o \\( -type d -name \"dist\" -o -name \".turbo\" -o -name \".next\" -o -name \".ploy\" \\) -exec rm -rf {} +",
		"dev": "ploy dev",
		"format": "turbo run format",
		"lint": "turbo run lint",
		"migrate": "pnpm --filter @llmchat/db migrate",
		"migrations": "pnpm --filter @llmchat/db migrations"
	},
	"devDependencies": {
		"@meetploy/cli": "^1.35.1",
		"@types/node": "^22.10.0",
		"prettier": "^3.6.2",
		"turbo": "^2.7.2",
		"typescript": "5.9.2"
	},
	"packageManager": "pnpm@10.0.0",
	"engines": {
		"node": ">=22"
	}
}
