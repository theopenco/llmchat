{
	"$schema": "https://turbo.build/schema.json",
	"globalDependencies": [
		"turbo.json",
		"package.json",
		"pnpm-lock.yaml",
		"pnpm-workspace.yaml",
		"tsconfig.base.json"
	],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", ".next/**", ".output/**"]
		},
		"dev": {
			"persistent": true,
			"cache": false
		},
		"lint": {},
		"format": {
			"cache": false
		},
		"test": {}
	}
}
